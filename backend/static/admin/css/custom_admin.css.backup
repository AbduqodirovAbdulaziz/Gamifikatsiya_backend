/* ═══════════════════════════════════════════════════════════════
   EduGame Admin  —  Jazzmin / AdminLTE 3  Custom Theme v2
   Rang palitra: Ko'k-siyoh sidebar + och fon + aniq kontrastlar
   ═══════════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

/* ── Design tokens ── */
:root {
  --sidebar-bg:          #1a1f36;
  --sidebar-border:      #252b45;
  --sidebar-text:        #a0aec0;
  --sidebar-text-muted:  #6b7a99;
  --sidebar-hover-bg:    #252b45;
  --sidebar-active-bg:   rgba(99,102,241,0.18);
  --sidebar-active-text: #c7d2fe;

  --primary:      #6366f1;
  --primary-dark: #4f52d9;
  --primary-glow: rgba(99,102,241,0.20);
  --primary-soft: rgba(99,102,241,0.08);

  --success: #10b981;
  --warning: #f59e0b;
  --danger:  #ef4444;
  --info:    #06b6d4;

  --page-bg:     #f4f6fb;
  --card-bg:     #ffffff;
  --card-border: #e5e9f2;
  --card-shadow: 0 1px 3px rgba(26,31,54,.07), 0 4px 12px rgba(26,31,54,.05);

  --text-900: #111827;
  --text-700: #374151;
  --text-500: #6b7280;
  --text-300: #9ca3af;

  --table-head-bg:  #f8faff;
  --table-head-text:#374151;
  --table-border:   #e5e9f2;
  --table-hover:    #eef2ff;

  --input-border: #d1d5db;
  --input-focus:  #6366f1;

  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;
  --transition: 0.18s ease;
  --font: 'Plus Jakarta Sans', system-ui, sans-serif;
  --mono: 'JetBrains Mono', monospace;
}

/* ── Base ── */
*, *::before, *::after { box-sizing: border-box; }

body,
.wrapper,
.content-wrapper,
.main-sidebar,
.main-header,
.nav-sidebar .nav-link p,
.card,
.table,
label,
.btn,
h1, h2, h3, h4, h5 {
  font-family: var(--font) !important;
  -webkit-font-smoothing: antialiased;
}

/* ════════════════════════════════════════
   HEADER / TOPBAR
════════════════════════════════════════ */
.main-header.navbar,
.main-header {
  background: var(--sidebar-bg) !important;
  border-bottom: 1px solid var(--sidebar-border) !important;
  box-shadow: 0 2px 12px rgba(0,0,0,0.25) !important;
  min-height: 54px !important;
}

.main-header .nav-link,
.main-header .navbar-nav > li > a,
.main-header .nav-item > a {
  color: rgba(255,255,255,0.82) !important;
  transition: var(--transition);
}
.main-header .nav-link:hover,
.main-header .navbar-nav > li > a:hover {
  color: #fff !important;
  background: rgba(255,255,255,0.08) !important;
  border-radius: var(--radius-sm);
}

/* Topbar search */
.main-header .form-control {
  background: rgba(255,255,255,0.08) !important;
  border: 1px solid rgba(255,255,255,0.14) !important;
  color: #fff !important;
  border-radius: 20px !important;
}
.main-header .form-control::placeholder { color: rgba(255,255,255,0.40) !important; }
.main-header .form-control:focus {
  border-color: var(--primary) !important;
  box-shadow: 0 0 0 3px var(--primary-glow) !important;
}

/* Hamburger / toggle */
[data-widget="pushmenu"] { color: rgba(255,255,255,0.75) !important; }
[data-widget="pushmenu"]:hover { color: #fff !important; }

/* ════════════════════════════════════════
   BRAND LINK
════════════════════════════════════════ */
.brand-link,
.main-sidebar .brand-link {
  background: rgba(0,0,0,0.25) !important;
  border-bottom: 1px solid var(--sidebar-border) !important;
  padding: 14px 18px !important;
  display: flex !important;
  align-items: center !important;
  gap: 10px;
}
.brand-text {
  color: #fff !important;
  font-size: 1.05rem !important;
  font-weight: 700 !important;
  letter-spacing: 0.01em;
}
.brand-link::before {
  content: '';
  display: inline-block;
  width: 8px; height: 8px;
  min-width: 8px;
  background: var(--primary);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--primary-glow);
}

/* ════════════════════════════════════════
   SIDEBAR
════════════════════════════════════════ */
.main-sidebar,
.main-sidebar .sidebar {
  background: var(--sidebar-bg) !important;
  border-right: 1px solid var(--sidebar-border) !important;
  box-shadow: none !important;
  width: 240px !important;
}

/* User panel */
.sidebar .user-panel {
  border-bottom: 1px solid rgba(255,255,255,0.07) !important;
  padding: 14px 18px !important;
}
.sidebar .user-panel .info a,
.sidebar .user-panel .info {
  color: rgba(255,255,255,0.88) !important;
  font-size: 0.875rem !important;
  font-weight: 500 !important;
}
.sidebar .user-panel .info small { color: var(--primary) !important; font-size: 0.72rem !important; }
.user-panel .image img { display: none !important; }
.user-panel .info { padding-left: 0 !important; }

/* Sidebar search */
.sidebar-search-results,
#sidebar-search-input {
  background: rgba(255,255,255,0.07) !important;
  border: 1px solid rgba(255,255,255,0.10) !important;
  color: #fff !important;
  border-radius: var(--radius-md) !important;
}
#sidebar-search-input::placeholder { color: var(--sidebar-text-muted) !important; }

/* Section headers */
.nav-sidebar .nav-header {
  color: rgba(255,255,255,0.28) !important;
  font-size: 0.60rem !important;
  font-weight: 700 !important;
  letter-spacing: 0.14em !important;
  text-transform: uppercase !important;
  padding: 18px 20px 5px !important;
}

/* Nav items */
.nav-sidebar .nav-item > .nav-link {
  color: var(--sidebar-text) !important;
  border-radius: var(--radius-md) !important;
  margin: 1px 8px !important;
  padding: 9px 14px !important;
  font-size: 0.855rem !important;
  font-weight: 400 !important;
  transition: var(--transition) !important;
  border-left: 3px solid transparent !important;
}
.nav-sidebar .nav-item > .nav-link .nav-icon {
  color: var(--sidebar-text-muted) !important;
  font-size: 0.90rem !important;
  width: 20px !important;
  margin-right: 10px !important;
  transition: color var(--transition) !important;
}
.nav-sidebar .nav-item > .nav-link:hover {
  color: #fff !important;
  background: var(--sidebar-hover-bg) !important;
  border-left-color: transparent !important;
}
.nav-sidebar .nav-item > .nav-link:hover .nav-icon { color: var(--primary) !important; }

/* Active */
.nav-sidebar .nav-item > .nav-link.active,
.nav-sidebar .nav-item.menu-open > .nav-link {
  color: var(--sidebar-active-text) !important;
  background: var(--sidebar-active-bg) !important;
  border-left-color: var(--primary) !important;
  font-weight: 600 !important;
}
.nav-sidebar .nav-item > .nav-link.active .nav-icon { color: var(--primary) !important; }

/* Sub items */
.nav-sidebar .nav-treeview .nav-link {
  color: var(--sidebar-text-muted) !important;
  padding-left: 36px !important;
  font-size: 0.82rem !important;
  border-radius: var(--radius-sm) !important;
  margin: 1px 8px 1px 18px !important;
  border-left: none !important;
}
.nav-sidebar .nav-treeview .nav-link:hover,
.nav-sidebar .nav-treeview .nav-link.active {
  color: #fff !important;
  background: var(--sidebar-hover-bg) !important;
}
.nav-sidebar .nav-treeview .nav-icon { color: rgba(99,102,241,0.45) !important; font-size: 0.50rem !important; }

/* ════════════════════════════════════════
   CONTENT WRAPPER
════════════════════════════════════════ */
.content-wrapper {
  background: var(--page-bg) !important;
}

/* Content header */
.content-header {
  background: var(--card-bg) !important;
  border-bottom: 1px solid var(--card-border) !important;
  padding: 12px 24px !important;
  box-shadow: 0 1px 4px rgba(26,31,54,.04) !important;
}
.content-header h1 {
  color: var(--text-900) !important;
  font-size: 1.12rem !important;
  font-weight: 700 !important;
}

/* Breadcrumb */
.breadcrumb {
  background: transparent !important;
  padding: 0 !important; margin: 0 !important;
}
.breadcrumb-item a { color: var(--primary) !important; font-weight: 500; }
.breadcrumb-item.active { color: var(--text-500) !important; }
.breadcrumb-item + .breadcrumb-item::before { color: var(--text-300) !important; }

/* ════════════════════════════════════════
   CARDS
════════════════════════════════════════ */
.card {
  background: var(--card-bg) !important;
  border: 1px solid var(--card-border) !important;
  border-radius: var(--radius-lg) !important;
  box-shadow: var(--card-shadow) !important;
  margin-bottom: 1.25rem;
  overflow: hidden;
  transition: box-shadow var(--transition);
}
.card:hover { box-shadow: 0 4px 20px rgba(26,31,54,.13) !important; }

.card-header {
  background: var(--card-bg) !important;
  border-bottom: 1px solid var(--card-border) !important;
  padding: 13px 18px !important;
  display: flex; align-items: center; gap: 10px;
}
.card-header h3,
.card-header .card-title {
  color: var(--text-900) !important;
  font-weight: 700 !important;
  font-size: 0.92rem !important;
  margin: 0 !important;
}
.card-header::before {
  content: '';
  display: inline-block;
  width: 3px; height: 16px;
  background: var(--primary);
  border-radius: 2px;
  flex-shrink: 0;
}

/* ════════════════════════════════════════
   TABLES  — aniq ko'rinadigan
════════════════════════════════════════ */
.table {
  color: var(--text-700) !important;
  font-size: 0.875rem !important;
  border-collapse: collapse;
}

.table thead th {
  background: var(--table-head-bg) !important;
  color: var(--table-head-text) !important;
  font-size: 0.71rem !important;
  font-weight: 700 !important;
  letter-spacing: 0.07em !important;
  text-transform: uppercase !important;
  border-top: none !important;
  border-bottom: 2px solid var(--table-border) !important;
  padding: 11px 14px !important;
  white-space: nowrap;
}

/* Sorting arrows ko'rinadigan bo'lsin */
.table thead th a,
.table thead th a:visited {
  color: var(--table-head-text) !important;
  font-weight: 700 !important;
}
.table thead th a:hover { color: var(--primary) !important; }

.table tbody td {
  color: var(--text-700) !important;
  border-bottom: 1px solid var(--table-border) !important;
  padding: 11px 14px !important;
  vertical-align: middle !important;
}

.table tbody tr:hover td {
  background: var(--table-hover) !important;
  color: var(--text-900) !important;
}
.table-striped tbody tr:nth-of-type(odd) td {
  background: rgba(99,102,241,0.025) !important;
}

/* Checkbox */
input[type="checkbox"], input[type="radio"] {
  accent-color: var(--primary) !important;
  width: 15px !important; height: 15px !important;
}

/* Selected rows */
.table tbody tr.selected td { background: rgba(99,102,241,0.09) !important; }

/* ════════════════════════════════════════
   FORMS & INPUTS
════════════════════════════════════════ */
.form-control,
.form-select,
select.form-control,
textarea.form-control {
  border: 1.5px solid var(--input-border) !important;
  border-radius: var(--radius-md) !important;
  color: var(--text-700) !important;
  font-family: var(--font) !important;
  font-size: 0.9rem !important;
  background: #fff !important;
  padding: 8px 13px !important;
  transition: var(--transition) !important;
  line-height: 1.5;
}
.form-control:focus,
.form-select:focus {
  border-color: var(--input-focus) !important;
  box-shadow: 0 0 0 3px var(--primary-glow) !important;
  outline: none !important;
  color: var(--text-900) !important;
}

label, .form-group label {
  color: var(--text-700) !important;
  font-weight: 600 !important;
  font-size: 0.84rem !important;
  margin-bottom: 5px !important;
}

.help-text, .helptext, p.help {
  color: var(--text-300) !important;
  font-size: 0.8rem !important;
}

/* ════════════════════════════════════════
   BUTTONS
════════════════════════════════════════ */
.btn {
  font-weight: 600 !important;
  font-size: 0.855rem !important;
  border-radius: var(--radius-md) !important;
  padding: 8px 18px !important;
  transition: var(--transition) !important;
  letter-spacing: 0.01em;
  border: none !important;
}
.btn:active { transform: scale(0.98); }

.btn-primary {
  background: var(--primary) !important;
  color: #fff !important;
  box-shadow: 0 2px 8px var(--primary-glow) !important;
}
.btn-primary:hover, .btn-primary:focus {
  background: var(--primary-dark) !important;
  color: #fff !important;
  transform: translateY(-1px);
  box-shadow: 0 4px 14px var(--primary-glow) !important;
}

.btn-info { background: var(--info) !important; color: #fff !important; }
.btn-info:hover { background: #0891b2 !important; color: #fff !important; }

.btn-success { background: var(--success) !important; color: #fff !important; }
.btn-success:hover { background: #059669 !important; color: #fff !important; }

.btn-danger { background: var(--danger) !important; color: #fff !important; }
.btn-danger:hover { background: #dc2626 !important; color: #fff !important; }

.btn-warning { background: var(--warning) !important; color: #fff !important; }
.btn-warning:hover { background: #d97706 !important; color: #fff !important; }

.btn-secondary {
  background: transparent !important;
  color: var(--text-500) !important;
  border: 1.5px solid var(--card-border) !important;
}
.btn-secondary:hover {
  background: var(--page-bg) !important;
  color: var(--text-700) !important;
}

.btn-sm {
  padding: 4px 11px !important;
  font-size: 0.78rem !important;
  border-radius: var(--radius-sm) !important;
}

/* ════════════════════════════════════════
   BADGES
════════════════════════════════════════ */
.badge {
  font-weight: 600 !important;
  font-size: 0.70rem !important;
  letter-spacing: 0.04em !important;
  padding: 3px 9px !important;
  border-radius: 20px !important;
}
.badge-primary, .badge.bg-primary { background: var(--primary) !important; color: #fff !important; }
.badge-info,    .badge.bg-info    { background: var(--info)    !important; color: #fff !important; }
.badge-success, .badge.bg-success { background: var(--success) !important; color: #fff !important; }
.badge-warning, .badge.bg-warning { background: var(--warning) !important; color: #fff !important; }
.badge-danger,  .badge.bg-danger  { background: var(--danger)  !important; color: #fff !important; }

/* ════════════════════════════════════════
   INFO BOXES (dashboard stats)
════════════════════════════════════════ */
.info-box {
  border-radius: var(--radius-lg) !important;
  box-shadow: var(--card-shadow) !important;
  border: 1px solid var(--card-border) !important;
  overflow: hidden;
  transition: var(--transition);
  background: var(--card-bg) !important;
}
.info-box:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(26,31,54,.13) !important; }

.info-box-icon {
  border-radius: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 1.5rem !important;
  color: #fff !important;
  width: 70px !important;
}
.info-box-content { padding: 12px 16px !important; }
.info-box-number {
  color: var(--text-900) !important;
  font-weight: 800 !important;
  font-size: 1.55rem !important;
}
.info-box-text {
  color: var(--text-500) !important;
  font-size: 0.80rem !important;
  text-transform: uppercase !important;
  letter-spacing: 0.06em !important;
  font-weight: 600 !important;
}

/* ════════════════════════════════════════
   ALERTS
════════════════════════════════════════ */
.alert {
  border-radius: var(--radius-md) !important;
  border: none !important;
  font-size: 0.875rem !important;
  border-left: 4px solid transparent !important;
  padding: 12px 18px !important;
  color: var(--text-700) !important;
}
.alert-success { background: #ecfdf5 !important; color: #065f46 !important; border-left-color: var(--success) !important; }
.alert-warning { background: #fffbeb !important; color: #92400e !important; border-left-color: var(--warning) !important; }
.alert-danger  { background: #fef2f2 !important; color: #991b1b !important; border-left-color: var(--danger)  !important; }
.alert-info    { background: #f0f9ff !important; color: #1e40af !important; border-left-color: var(--info)    !important; }

/* ════════════════════════════════════════
   PAGINATION
════════════════════════════════════════ */
.pagination .page-link {
  color: var(--text-700) !important;
  border-radius: var(--radius-sm) !important;
  margin: 0 2px;
  border-color: var(--card-border) !important;
  font-size: 0.855rem !important;
  transition: var(--transition);
  background: var(--card-bg) !important;
}
.pagination .page-item.active .page-link {
  background: var(--primary) !important;
  border-color: var(--primary) !important;
  color: #fff !important;
}
.pagination .page-link:hover {
  background: var(--primary-soft) !important;
  color: var(--primary) !important;
  border-color: var(--primary) !important;
}

/* ════════════════════════════════════════
   SELECT2
════════════════════════════════════════ */
.select2-container--default .select2-selection--single,
.select2-container--default .select2-selection--multiple {
  border: 1.5px solid var(--input-border) !important;
  border-radius: var(--radius-md) !important;
  min-height: 38px !important;
  font-family: var(--font) !important;
  color: var(--text-700) !important;
}
.select2-container--default.select2-container--focus .select2-selection--single,
.select2-container--default.select2-container--focus .select2-selection--multiple {
  border-color: var(--primary) !important;
  box-shadow: 0 0 0 3px var(--primary-glow) !important;
}
.select2-results__option { font-family: var(--font) !important; font-size: 0.875rem !important; }
.select2-container--default .select2-results__option--highlighted[aria-selected] {
  background: var(--primary) !important; color: #fff !important;
}
.select2-dropdown {
  border: 1px solid var(--card-border) !important;
  border-radius: var(--radius-md) !important;
  box-shadow: var(--card-shadow) !important;
}

/* ════════════════════════════════════════
   FILTER SIDEBAR (changelist)
════════════════════════════════════════ */
#changelist-filter {
  background: var(--card-bg) !important;
  border: 1px solid var(--card-border) !important;
  border-radius: var(--radius-lg) !important;
  box-shadow: var(--card-shadow) !important;
  overflow: hidden;
}
#changelist-filter h2 {
  background: var(--table-head-bg) !important;
  color: var(--text-900) !important;
  font-size: 0.70rem !important;
  font-weight: 800 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.10em !important;
  padding: 12px 16px !important;
  border-bottom: 1px solid var(--table-border) !important;
  margin: 0 !important;
}
#changelist-filter h3 {
  color: var(--text-500) !important;
  font-size: 0.70rem !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
  letter-spacing: 0.08em !important;
  padding: 12px 16px 4px !important;
  margin: 0 !important;
}
#changelist-filter ul { padding: 0 0 8px !important; margin: 0 !important; list-style: none; }
#changelist-filter li { padding: 0 !important; }
#changelist-filter li a {
  display: block;
  padding: 7px 16px !important;
  color: var(--text-700) !important;
  font-size: 0.84rem !important;
  transition: var(--transition);
}
#changelist-filter li a:hover,
#changelist-filter li.selected a {
  background: var(--primary-soft) !important;
  color: var(--primary) !important;
}
#changelist-filter li.selected a { font-weight: 700 !important; }

/* ════════════════════════════════════════
   LOGIN PAGE
════════════════════════════════════════ */
.login-page {
  background: var(--sidebar-bg) !important;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(99,102,241,0.15) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(99,102,241,0.08) 0%, transparent 50%) !important;
}
.login-logo a, .login-logo {
  color: #fff !important;
  font-weight: 800 !important;
  font-size: 1.75rem !important;
}
.login-card-body {
  background: #fff !important;
  border-radius: var(--radius-lg) !important;
  box-shadow: 0 20px 60px rgba(0,0,0,0.35) !important;
  border: none !important;
  padding: 30px !important;
}
.login-card-body .form-control {
  border-radius: var(--radius-md) !important;
}

/* ════════════════════════════════════════
   FOOTER
════════════════════════════════════════ */
.main-footer {
  background: var(--card-bg) !important;
  border-top: 1px solid var(--card-border) !important;
  color: var(--text-300) !important;
  font-size: 0.82rem !important;
  padding: 12px 24px !important;
}
.main-footer a { color: var(--primary) !important; }

/* ════════════════════════════════════════
   MISC FIXES
════════════════════════════════════════ */
/* Page animation */
.content-wrapper { animation: fadeIn 0.25s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* Scrollbar */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: #9ca3af; }

/* Callout */
.callout {
  border-radius: var(--radius-md) !important;
  border-left: 4px solid var(--primary) !important;
  background: var(--primary-soft) !important;
}
.callout-info { border-left-color: var(--info) !important; background: #f0f9ff !important; }
.callout-warning { border-left-color: var(--warning) !important; background: #fffbeb !important; }
.callout-danger { border-left-color: var(--danger) !important; background: #fef2f2 !important; }

/* Error messages */
.errorlist {
  color: #991b1b !important;
  background: #fef2f2 !important;
  border: 1px solid #fecaca !important;
  border-radius: var(--radius-sm) !important;
  padding: 8px 14px !important;
  list-style: none !important;
  font-size: 0.85rem !important;
}

/* Inline admin tabular */
.inline-group .tabular { border-radius: 0 0 var(--radius-lg) var(--radius-lg) !important; }

/* Related lookup popup buttons */
.related-widget-wrapper a { color: var(--primary) !important; }

/* Object tools */
.object-tools li a {
  background: var(--primary) !important;
  border-radius: 20px !important;
  font-size: 0.80rem !important;
  font-weight: 600 !important;
  color: #fff !important;
  padding: 6px 16px !important;
}
.object-tools li a:hover { background: var(--primary-dark) !important; }
