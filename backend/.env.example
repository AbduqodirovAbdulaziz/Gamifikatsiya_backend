# =============================================================================
# backend/.env — namuna (maxfiy emas). Haqiqiy qiymatlar: faqat mahalliy .env da.
# Yaratish:  copy .env.example .env   (.env gitga tushmaydi)
# =============================================================================

# -----------------------------------------------------------------------------
# A) MAHALLIY ISHLASH (development) — SQLite, DEBUG
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=mahalliy-dev-uchun-50-belgi-yoki-undan-uzun-tasodifiy-qator
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# DATABASE_URL bo‘lmasa, quyidagi SQLite ishlatiladi (base.py)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Mobil / frontend (development) — base.py dagi defaultlarni bekor qilish uchun
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8081

# -----------------------------------------------------------------------------
# B) SUPABASE POSTGRES — Render va mahalliy “production” test uchun bir xil URI
# -----------------------------------------------------------------------------
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# Parolni [YOUR-PASSWORD] o‘rniga qo‘ying (maxsus belgilar bo‘lsa URL-encode qiling).
#
# Variant 1 — Transaction pooler (odatda port 6543, host ...pooler.supabase.com)
#   Migratsiya ba’zan xato bersa, Variant 2 dan foydalaning.
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Variant 2 — To‘g‘ridan-to‘g‘ri ulanish (port 5432) — migrate/createuser uchun qulay
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres
#
# SSL: kodda sslmode=require avtomatik qo‘shiladi; URI oxirida ?sslmode=require bo‘lishi ham mumkin.

# -----------------------------------------------------------------------------
# C) RENDER PRODUCTION (server bilan bir xil o‘zgaruvchilar — mahalliy sinash)
# -----------------------------------------------------------------------------
# migrate / createsuperuser ni production bazaga qilish uchun vaqtincha yoqing:
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=<Render Environment dagi yoki yangi kuchli kalit>
# DATABASE_URL=<yuqoridagi Supabase URI>
#
# Domen va CORS (Flutter / brauzer manzillari — https, oxirida / yo‘q)
# RENDER_EXTERNAL_URL=https://your-service-name.onrender.com
# RENDER_EXTERNAL_HOSTNAME=your-service-name.onrender.com
# FRONTEND_URL=https://your-frontend-or-app.example.com
# CORS_ALLOWED_ORIGINS=https://your-frontend-or-app.example.com,http://localhost:8081
# CSRF_TRUSTED_ORIGINS=https://your-frontend-or-app.example.com,http://localhost:8081
#
# ALLOWED_HOSTS ixtiyoriy — bo‘sh bo‘lsa RENDER_EXTERNAL_URL / RENDER_EXTERNAL_HOSTNAME ishlatiladi
# ALLOWED_HOSTS=your-service-name.onrender.com,.onrender.com

# Mahalliy HTTPS redirect sinovi kerak bo‘lmasa (ba’zan localhost redirect muammosi):
# SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------------
# D) REDIS (ixtiyoriy) — cache, Channels, Celery bir vaqtda
# -----------------------------------------------------------------------------
# Mahalliy: redis://localhost:6379/0
# Render: alohida Redis plugin yoki tashqi URL
# REDIS_URL=redis://default:password@host:6379/0

# -----------------------------------------------------------------------------
# E) PUSH / FIREBASE (ixtiyoriy)
# -----------------------------------------------------------------------------
# FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# FIREBASE_PROJECT_ID=your-firebase-project-id

# -----------------------------------------------------------------------------
# Render avtomatik beradi (odatda .env da yozmaydi; faqat ma’lumot uchun)
# PORT, RENDER=true, RENDER_EXTERNAL_URL (ba’zi rejalar)
# =============================================================================
